{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "command -v arbiterx >/dev/null 2>&1 && echo 'ArbiterX engineering mode active.' || echo 'ArbiterX not installed. Run: pip install arbiterx-gate'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "command -v arbiterx >/dev/null 2>&1 && arbiterx gate --file \"$CLAUDE_TOOL_INPUT_FILE_PATH\" --json 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "command -v arbiterx >/dev/null 2>&1 && echo 'Run arbiterx gate on changed files to verify quality before committing.' || true"
          }
        ]
      }
    ]
  }
}
